{{ if eq .chezmoi.os "darwin" -}}
#!/bin/sh
{{ range .packages.mac.pkgs -}}
    brew install {{ .name | quote }}
{{ end -}}
{{ end -}}
{{ if eq .chezmoi.os "linux" -}}
#!/bin/sh
sudo apt-get install -y software-properties-common
sudo add-apt-repository -y ppa:aos1/diff-so-fancy
sudo add-apt-repository ppa:neovim-ppa/unstable -y
sudo add-apt-repository -y universe

curl -sSL https://ngrok-agent.s3.amazonaws.com/ngrok.asc \
  | sudo tee /etc/apt/trusted.gpg.d/ngrok.asc >/dev/null \
  && echo "deb https://ngrok-agent.s3.amazonaws.com buster main" \
  | sudo tee /etc/apt/sources.list.d/ngrok.list

sudo apt update


{{ range .packages.ubuntu.pkgs -}}
{{ if .install -}}
{{ if .check -}}
if ! {{ .check }} >/dev/null 2>&1; then
{{ .install -}}
fi
{{ else -}}
{{ .install -}}
{{ end -}}
{{ else -}}
    sudo apt install -y {{ .name | quote }}
{{ end -}}
{{ end -}}

rustup default stable
{{ range .packages.ubuntu.rustpkgs -}}
    cargo install --locked {{ .name | quote }}
{{ end -}}
{{ range .packages.ubuntu.rustpkgsgit -}}
{{ if .install -}}
    {{ .install }}
{{ else -}}
    cargo install --git https://github.com/{{ .name }}
{{ end -}}
{{ end -}}

if [ ! -d "${ZDOTDIR:-$HOME}/.zprezto" ]; then
  echo "Warning: Prezto directory not found at ${ZDOTDIR:-$HOME}/.zprezto"
  git clone --recursive https://github.com/sorin-ionescu/prezto.git "${ZDOTDIR:-$HOME}/.zprezto"
fi

if command -v claude >/dev/null 2>&1; then
   echo "claude is already installed"
else
  curl -fsSL https://claude.ai/install.sh | bash -s latest
  rtk init -g
fi
{{ end -}}
