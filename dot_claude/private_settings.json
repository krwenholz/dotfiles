{
  "editorMode": "vim",
  "enabledPlugins": {
    "elements-of-style@superpowers-marketplace": true,
    "episodic-memory@superpowers-marketplace": true,
    "hookify@claude-plugins-official": true,
    "kyle-wenholz@maintainx-skills": true,
    "playwright@claude-plugins-official": true,
    "superpowers-lab@superpowers-marketplace": true,
    "superpowers@superpowers-dev": true,
    "superpowers@superpowers-marketplace": true
  },
  "extraKnownMarketplaces": {
    "maintainx-skills": {
      "source": {
        "ref": "krw/plugin-marketplace",
        "repo": "MaintainX/skill-share",
        "source": "github"
      }
    },
    "superpowers-marketplace": {
      "source": {
        "repo": "obra/superpowers",
        "source": "github"
      }
    }
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "/usr/local/bin/aicodemetricsd hook claude --hook-input stdin",
            "timeout": 2,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit|MultiEdit"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "/usr/local/bin/aicodemetricsd hook claude --hook-input stdin",
            "timeout": 2,
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "$HOME/.claude/hooks/jj-git-guard/scripts/block-git-in-jj.sh",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "rtk hook claude",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "/usr/local/bin/aicodemetricsd hook claude --hook-input stdin",
            "timeout": 2,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit|MultiEdit"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "/usr/local/bin/aicodemetricsd hook claude --hook-input stdin",
            "timeout": 2,
            "type": "command"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(/usr/bin/make check:*)",
      "Bash(bash -c:*)",
      "Bash(cat:*)",
      "Bash(curl:*)",
      "Bash(docker-compose ps:*)",
      "Bash(docker-compose restart:*)",
      "Bash(podman build:*)",
      "Bash(podman compose logs:*)",
      "Bash(podman compose ps:*)",
      "Bash(podman compose restart:*)",
      "Bash(podman exec:*)",
      "Bash(podman images:*)",
      "Bash(podman pull:*)",
      "Bash(podman info:*)",
      "Bash(podman inspect:*)",
      "Bash(podman logs:*)",
      "Bash(podman port:*)",
      "Bash(podman ps:*)",
      "Bash(podman stats:*)",
      "Bash(podman top:*)",
      "Bash(podman version:*)",
      "Bash(echo:*)",
      "Bash(env)",
      "Bash(find:*)",
      "Bash(read:*)",
      "Read",
      "Grep",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(git add:*)",
      "Bash(git log:*)",
      "Bash(git mv:*)",
      "Bash(grep:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npx eslint:*)",
      "Bash(npx prettier:*)",
      "Bash(npx tsc:*)",
      "Bash(poetry add:*)",
      "Bash(poetry env info:*)",
      "Bash(poetry run alembic revision:*)",
      "Bash(poetry run:*)",
      "Bash(python -m mypy:*)",
      "Bash(python:*)",
      "Bash(terraform fmt:*)",
      "Bash(terraform validate:*)",
      "Bash(tree:*)",
      "Bash(rtk:*)",
      "Bash(xargs ls:*)",
      "Read(//tmp/**)",
      "Skill(episodic-memory:remembering-conversations)",
      "Skill(superpowers:brainstorming)",
      "Skill(superpowers:test-driven-development)",
      "WebFetch(domain:docs.stripe.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:linear.app)",
      "WebFetch(domain:stackoverflow.com)",
      "WebFetch(domain:uploads.linear.app)",
      "WebSearch",
      "mcp__figma__get_design_context",
      "mcp__figma__get_screenshot",
      "mcp__github__get_me",
      "mcp__github__pull_request_read",
      "mcp__github__search_pull_requests",
      "mcp__linear__create_issue",
      "mcp__linear__get_issue",
      "mcp__linear__list_comments",
      "mcp__linear__list_comments",
      "mcp__metabase__executeQuery",
      "mcp__metabase__listDashboards",
      "mcp__metabase__listDatabases",
      "mcp__plugin_episodic-memory_episodic-memory__search",
      "Bash(jj:*)"
    ],
    "defaultMode": "auto"
  },
  "skipAutoPermissionPrompt": true,
  "statusLine": {
    "command": "bash $HOME/.claude/statusline-command.sh",
    "type": "command"
  }
}
